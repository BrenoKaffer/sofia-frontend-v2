# Configurações do Projeto SOFIA
# Copie este arquivo para .env.local e configure as variáveis

# === SUPABASE AUTHENTICATION ===
# Configurações do Supabase - Projeto SOFIA
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# URLs de redirecionamento após login/logout
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === CLERK AUTHENTICATION (OPCIONAL) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# === SENTRY MONITORING ===
SENTRY_DSN=your_sentry_dsn_here

# === CONFIGURAÇÕES SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email_here
SMTP_PASS=your_email_password_here

# === CONFIGURAÇÕES DE NOTIFICAÇÕES ===
EMAIL_ENABLED=true
WEBHOOK_ENABLED=false
EMAIL_RATE_LIMIT_PER_HOUR=50
WEBHOOK_RATE_LIMIT_PER_HOUR=100

# === CONFIGURAÇÕES DE RETRY ===
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000

# === CONFIGURAÇÕES DE DESENVOLVIMENTO ===
# Configuração para dados simulados (temporário para testes)
USE_MOCK_DATA=false

# === APIS EXTERNAS ===
# CPF Hub API para validação de CPF
CPF_HUB_API_KEY=your_cpf_hub_api_key_here

# Backend API Configuration
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=your_backend_api_key_here
# Test-only key (não use em produção)
TEST_BACKEND_API_KEY=your_backend_test_api_key_here

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Pagar.me Configuration
PAGARME_API_KEY=your_pagarme_api_key_here
PAGARME_WEBHOOK_SECRET=your_pagarme_webhook_secret_here

# Auth Development Bypass (APENAS PARA DESENVOLVIMENTO)
NEXT_PUBLIC_AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS=false

# Configuração da porta do servidor
PORT=3000

# URLs das APIs (usando Next.js API routes)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_PUBLIC_API_URL=/api/public

# Base URL explícita para APIs (opcional, priorizada se definida)
# Ex.: http://localhost:3002/api em dev, https://api.sofia.com.br/api em prod
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_BACKEND_URL=

# Servidor WebSocket Interno (não exposto publicamente)
INTERNAL_WS_HOST=127.0.0.1
INTERNAL_WS_PORT=3002

# === CONFIGURAÇÕES DO BACKEND SOFIA ===
# URL do backend SOFIA (localhost para desenvolvimento)
SOFIA_BACKEND_URL=http://localhost:3001
SOFIA_BACKEND_WS_URL=ws://localhost:3001

# === TESTES (E2E e integração) ===
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_TEST_NAME=Test User
TEST_REG_EMAIL=
TEST_REG_PASSWORD=

# === CONFIGURAÇÕES DE PRODUÇÃO (comentadas para desenvolvimento) ===
# NEXT_PUBLIC_SITE_URL=https://sofia.vercel.app
# SOFIA_BACKEND_URL=https://api.sofia.com.br
# SOFIA_BACKEND_WS_URL=wss://api.sofia.com.br